# -----------------------------------------------------------
# 🛡️ CONFIGURACIÓN VANTEC VCORE v5.0.1 (SANDBOX)
# -----------------------------------------------------------

# 1. Configuración Base de Datos (Protocolo Blanco)
# La base de datos debe estar vacía para el primer arranque.
DATABASE_URL=postgresql+asyncpg://postgres:admin123@localhost:5432/vcore_blank_db

# 2. Seguridad Atómica
VANTEC_SECRET_KEY=ingrese_su_llave_aqui_para_jwt_segurity
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2

# 3. Configuración SMTP (Obligatorio para microservicio mailVantec)
# Sin esta configuración, el envío de comprobantes fallará.
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=correo@ejemplo.com
SMTP_PASSWORD=tu_password_aqui
SMTP_FROM_ADDRESS=noreply@vantec.com

# 4. Almacenamiento SSoT
# Rutas absolutas para el almacenamiento de archivos CFDI
STORAGE_PATH=C:\Test_Antigravity\Gestor_CFDI_Vantec\storage
VANTEC_CFDI_ROOT=C:\Test_Antigravity\Gestor_CFDI_Vantec\storage

# 5. Tiempos de Sesión
SESSION_INACTIVITY_TIMEOUT_MINUTES=15
SESSION_MAX_LIFETIME_MINUTES=30
